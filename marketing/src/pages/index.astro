---
import Layout from '../layouts/Layout.astro'

const SIGNUP_URL = 'https://app.stratareport.ai/auth/register'

const plans = [
  {
    id: 'starter',
    name: 'Starter',
    price: 29,
    description: 'For owners getting started with strata reporting.',
    features: [
      'Up to 5 properties',
      '4 reports per quarter included',
      'Email support',
    ],
  },
  {
    id: 'pro',
    name: 'Pro',
    price: 79,
    description: 'For growing portfolios that need more reports.',
    features: [
      'Up to 20 properties',
      '20 reports per quarter included',
      'Priority email support',
    ],
    highlighted: true,
  },
  {
    id: 'scale',
    name: 'Scale',
    price: 199,
    description: 'For high-volume operators who need unlimited reporting.',
    features: [
      'Up to 50 properties',
      'Unlimited reports',
      'Priority support',
    ],
  },
]

const features = [
  {
    title: 'AI narrative reports',
    body:
      'Plain-English narrative reports that explain what changed, why it matters, and what to do next — no spreadsheet wrangling required.',
  },
  {
    title: 'Multi-source synthesis',
    body:
      'Bring rent rolls, ledgers, work orders and meeting minutes into one place. We synthesise them into a single coherent picture.',
  },
  {
    title: '10-minute first report',
    body:
      'Upload your CSVs and get a complete first strata report in under ten minutes. No onboarding calls, no setup fees.',
  },
]
---

<Layout
  title="StrataReport AI — AI-powered strata reports in minutes"
  description="StrataReport AI turns rent rolls, ledgers and meeting minutes into clear, narrative strata reports — your first report in under ten minutes."
>
  <section class="hero">
    <div class="container hero-inner">
      <h1>AI-powered strata reports in minutes.</h1>
      <p class="lede">
        StrataReport AI synthesises your rent rolls, ledgers and meeting
        minutes into clear, narrative reports your owners actually read.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href={SIGNUP_URL}>Get started free</a>
        <a class="btn btn-ghost" href="/pricing/">See pricing</a>
      </div>
      <p class="hero-meta">No credit card required. First report in 10 minutes.</p>
    </div>
  </section>

  <section id="features" class="features">
    <div class="container">
      <h2 class="section-title">Built for property managers who hate spreadsheets.</h2>
      <ul class="feature-grid" role="list">
        {features.map((f) => (
          <li class="feature-card">
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section id="pricing" class="pricing">
    <div class="container">
      <h2 class="section-title">Simple monthly pricing.</h2>
      <p class="section-sub">Cancel anytime. All prices in AUD.</p>
      <div class="pricing-grid">
        {plans.map((p) => (
          <article class={`plan ${p.highlighted ? 'plan-highlight' : ''}`}>
            {p.highlighted && <div class="plan-badge">Most popular</div>}
            <h3 class="plan-name">{p.name}</h3>
            <p class="plan-desc">{p.description}</p>
            <p class="plan-price">
              <span class="price-amount">${p.price}</span>
              <span class="price-period">/mo</span>
            </p>
            <ul class="plan-features" role="list">
              {p.features.map((feature) => (
                <li>{feature}</li>
              ))}
            </ul>
            <a class="btn btn-primary plan-cta" href={SIGNUP_URL}>Get started</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-banner">
    <div class="container cta-banner-inner">
      <h2>Ready to ship your next report in minutes?</h2>
      <a class="btn btn-primary" href={SIGNUP_URL}>Create your account</a>
    </div>
  </section>
</Layout>
